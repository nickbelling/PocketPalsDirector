        "@angular/compiler-cli": "^21.2.8",
        "@babel/preset-env": "^7.26.8",
        "@babel/preset-typescript": "^7.28.5",
        "@jest/types": "^30.3.0",
        "@testing-library/angular": "^19.2.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@types/deep-equal": "^1.0.4",
        "@types/jest": "^30.0.0",
        "@types/pica": "^9.0.5",
